# ── Aplicação ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_BASE_URL=http://localhost:8000
APP_ALLOWED_ORIGINS=http://localhost:8000

# ── Banco de dados (Supabase Postgres) ─────────────────────────────────────
# String de conexão async (usada pela aplicação em runtime).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/triade
# String de conexão síncrona (usada pelo Alembic para migrations).
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/triade

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=attachments

# ── OAuth (via Supabase Auth) ───────────────────────────────────────────────
OAUTH_REDIRECT_URL=http://localhost:8000/auth/callback

# ── Cookies / Sessão ────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=triade_session
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_NAME=triade_csrf

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
